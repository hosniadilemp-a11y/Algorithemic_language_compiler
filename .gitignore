# ============================================================
# AlgoCompiler — .gitignore
# ============================================================
docs/CoursAlgo
examples/Tests
tests/*.py

# --- Python cache ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Virtual environments ---
venv/
env/
.venv/
.env/

# --- PLY parser cache ---
src/compiler/parser.out
src/compiler/parsetab.py

# --- Test artifacts ---
.pytest_cache/
*.egg-info/
dist/
build/

# --- IDE / Editor settings ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.DS_Store
Thumbs.db

# --- Logs & temporary files ---
*.log
*.tmp
nul

# --- SCRATCH FILES (Generated during development) ---
check_braces*.py
check.js
test.js
test_script.js
script_*.js
*.txt
!README.md
!requirements.txt
!Badges.txt
!OAUTH_SETUP_INSTRUCTIONS.md
!README_DEPLOY.md

# --- DATABASE & USER DATA (DO NOT COMMIT) ---
# # Ignore all SQLite databases to protect user privacy
# src/web/*.db
# src/web/*.db-journal
# src/web/*.db-shm
# src/web/*.db-wal
# algocompiler.db
# *.db

# # --- SOURCE DATASET (DO COMMIT) ---
# # These are the original JSONs for quizzes/problems
# !src/web/data/
# !src/web/data/quizzes/
# !src/web/data/quizzes/*.json
# !src/web/data/quizzes/.gitkeep

# --- Archive / draft files ---
archive/
ppts/

# # --- Local problem solution notes ---
# src/web/data/problem_solutions_txt/

# Local-only tools
local_admin/
update_users_db.py
fix_chapters.py
patch_*.py
run_examples.py
check_*.py
verify_*.py
seed_additional_quizzes.py
repair_json_content.py
traceback_debug.txt
check_results.txt
test_results.txt
